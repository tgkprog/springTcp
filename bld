#!/bin/bash
# Build script for TCP TGK project

echo "=========================================="
echo "Building TCP TGK Project"
echo "=========================================="

# Change to project root
cd "$(dirname "$0")"

# Clean and package (not install)
echo "Running Maven clean package..."
mvn clean package -DskipTests

if [ $? -eq 0 ]; then
    echo ""
    echo "=========================================="
    echo "Build SUCCESS"
    echo "=========================================="
    echo "Server JAR: tcp-server/target/tcp-server-1.0.0.jar"
    echo "Client JAR: tcp-client/target/tcp-client-1.0.0.jar"
    echo ""
    echo "To run:"
    echo "  Server: ./runS"
    echo "  Client: ./runC"
    echo "=========================================="
    exit 0
else
    echo ""
    echo "=========================================="
    echo "Build FAILED"
    echo "=========================================="
    exit 1
fi
