#!/bin/bash
# Test script to demonstrate connection monitoring

echo "=========================================="
echo "Connection Monitoring Test"
echo "=========================================="
echo ""

cd "$(dirname "$0")"

# Start server
echo "1. Starting server..."
./runS > /tmp/monitor-test-server.log 2>&1 &
SRV_PID=$!
sleep 5

# Start client with monitoring enabled
echo "2. Starting client with monitoring ENABLED..."
echo "   Check logs/tcp-client.log for monitoring messages"
echo ""

# Run client with monitoring profile
java -jar tcp-client/target/tcp-client-1.0.0.jar \
  --tcp.client.monitoring.enabled=true \
  --tcp.client.monitoring.tick-ms=3000 &
CLIENT_PID=$!

sleep 8

echo "3. Client should be connected and monitoring every 3 seconds"
echo "   Check the logs:"
echo ""
tail -15 logs/tcp-client.log | grep -E "(Monitoring|status|Successfully)"
echo ""

echo "4. Wait for monitoring cycles (watching for 10 seconds)..."
sleep 10

echo ""
echo "5. Recent log entries:"
tail -20 logs/tcp-client.log | grep -E "(health check|status|probe)"

echo ""
echo "=========================================="
echo "Test complete! Check logs/tcp-client.log for full details"
echo "=========================================="
echo ""
echo "To stop:"
echo "  kill $CLIENT_PID  # Client"
echo "  kill $SRV_PID     # Server"
